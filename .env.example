# --- コンテナ化した opencode 用（docker compose で必須） ---
# litellm 互換エンドポイントと API キー（opencode/opencode.json から {env:...} で参照）。
LITELLM_BASE_URL=
LITELLM_API_KEY=

# --- PKM vault（必須）---
# コンテナの /ref/pkm-private にマウントする Obsidian vault のホスト側絶対パス。
PKM_VAULT_PATH=

# --- GitHub 連携（AI に git の pull/commit/push を任せる）---
# Fine-grained PAT。対象リポジトリの Contents: Read and write（PR も使うなら Pull requests も）。
# gh が GH_TOKEN を自動で読むためブラウザ認証は不要。
GH_TOKEN=
# AI が作るコミットの著者情報（compose で GIT_AUTHOR_*/GIT_COMMITTER_* に展開される）。
GIT_USER_NAME=
GIT_USER_EMAIL=
