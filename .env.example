# --- コンテナ化した opencode 用（docker compose で必須） ---
# litellm 互換エンドポイントと API キー（opencode/opencode.json から {env:...} で参照）。
LITELLM_BASE_URL=https://your-litellm-host/v1
LITELLM_API_KEY=

# --- PKM vault（必須）---
# コンテナの /ref/pkm-private にマウントする Obsidian vault のホスト側絶対パス。
PKM_VAULT_PATH=/home/ubuntu/pkm-private
