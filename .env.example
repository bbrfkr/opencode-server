# --- コンテナ化した opencode サーバー用（docker compose で必須） ---
# litellm 互換エンドポイントと API キー（opencode/opencode.json から {env:...} で参照）。
LITELLM_BASE_URL=
LITELLM_API_KEY=
# opencode が使うモデル名（opencode/opencode.json の "model" から {env:...} で参照）。
# provider/model 形式で指定（例 bbrfkr-llm/bbrfkr-llm-coding）。
OPENCODE_MODEL_NAME=

# --- ホスト側 listen port（任意・既定 4096）---
# 同一ホストで複数の opencode-server を起動する場合にポート衝突を避けるため可変。
# コンテナ内は 4096 固定。クライアントの OPENCODE_BASE_URL もこの値に合わせること。
OPENCODE_PORT=4096

# --- project root（必須）---
# コンテナの /root/project にマウントする対象のホスト側絶対パス（用途で切替）。
#   - PKM 用途: Obsidian vault のパス
#   - bot 用途: n8n ワークフロー仕様リポ等のパス
#   - コーディング用途: 空のワークスペースディレクトリ（例 /home/ubuntu/workspace）。
#     AI が discord 経由でこの配下に repo 群を clone し、mise で言語ランタイムを入れて作業する。
PROJECT_PATH=

# --- スキル集（必須）---
# 共通の .claude ディレクトリ（dot-claude リポジトリ。Claude Code・opencode 双方で使う defuddle 等）の
# ホスト側絶対パス。コンテナの /root/.claude にまるごとマウントされ、opencode のグローバル .claude 互換パス
# ~/.claude/skills/*/SKILL.md として探索される（PROJECT_PATH に依存せず全用途で効く）。
DOT_CLAUDE_PATH=
# opencode 固有の .opencode ディレクトリ（dot-opencode リポジトリ。plugins/github-token.js + skills/ +
# AGENTS.md を内包）のホスト側絶対パス。コンテナの /root/.config/opencode にまるごとマウントされ、
# プラグイン（~/.config/opencode/plugins/*.js）・スキル（~/.config/opencode/skills/*/SKILL.md）・
# グローバル指針（~/.config/opencode/AGENTS.md）がいずれも PROJECT_PATH に依存せず効く。
# 収録スキルは web-search / gdrive / github-token / comfyui-image / interest-news / pomodoro / pdf 等。
DOT_OPENCODE_PATH=

# --- GitHub 連携（AI に git の pull/commit/push や gh コマンドを任せる）---
# git の HTTPS 認証も gh の API 認証も n8n ブローカー経由の短命トークンで行う（静的な GitHub トークンは不要）。
# opencode プラグインが git の network 操作・gh 実行時に POST /github/token で発行し、完了後 POST /github/revoke で失効する。
# 下は github-token ワークフローの Webhook 親 URL（/github/token・/github/revoke の手前、/webhook まで）。
N8N_WEBHOOK_BASE_URL=https://n8n.external.dynamis.bbrfkr.net/webhook
# AI が作るコミットの著者情報（compose で GIT_AUTHOR_*/GIT_COMMITTER_* に展開される）。
GIT_USER_NAME=
GIT_USER_EMAIL=
