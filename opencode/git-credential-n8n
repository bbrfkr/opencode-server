#!/usr/bin/env bash
# git credential helper（受け渡し専用・薄い実装）。
#
# n8n ブローカーへの「発行/失効」は opencode プラグイン
# (~/.config/opencode/plugins/github-token.js) が担当する。このヘルパは
# プラグインが書き出した短命トークンを git に渡すだけで、n8n は一切叩かない。
#
#   - プラグインの tool.execute.before が POST /github/token して
#     /tmp/n8n-gh-token に短命トークン（ghs_...）を書く
#   - git が github.com への認証時に本ヘルパの `get` を呼ぶ → ファイルを読んで返す
#   - プラグインの tool.execute.after が POST /github/revoke して失効・ファイル削除
#
# トークンをコマンド文字列に埋め込まずに渡せるのが狙い（ログ/履歴に残さない）。
# `git config --system credential.https://github.com.helper` に登録して使う。
set -euo pipefail

# git は最初の引数に操作種別（get / store / erase）を渡す。
# 認証情報の払い出しは get のときだけ。store / erase では何もしない
# （ファイルのライフサイクルはプラグインが管理する）。
if [ "${1:-}" != "get" ]; then
  exit 0
fi

token="$(cat /tmp/n8n-gh-token 2>/dev/null || true)"

# トークン未配置（プラグインが発行していない git 操作）なら何も返さない。
# git は認証情報なしとして扱い、当該操作は認証エラーで失敗する。
if [ -z "$token" ]; then
  exit 0
fi

# x-access-token をユーザ名にするのが GitHub App installation token の作法。
# stdout は git が読む credential プロトコル。トークンを含むため echo/ログ厳禁。
printf 'username=x-access-token\npassword=%s\n' "$token"
