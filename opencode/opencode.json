{
  "$schema": "https://opencode.ai/config.json",
  "model": "{env:OPENCODE_MODEL_NAME}",
  "provider": {
    "bbrfkr-llm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "BBRFKR LLM",
      "options": {
        "baseURL": "{env:LITELLM_BASE_URL}",
        "apiKey": "{env:LITELLM_API_KEY}"
      },
      "models": {
        "auto": {
          "name": "auto",
          "attachment": true,
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        }
      }
    }
  }
}
